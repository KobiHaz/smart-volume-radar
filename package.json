{
  "name": "smart-volume-radar",
  "version": "1.0.32",
  "description": "Automated stock volume monitoring system with RVOL analysis, news enrichment, and Telegram delivery",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "evaluate-setups": "tsx scripts/evaluate-setups.ts",
    "evaluate-setups-30d": "tsx scripts/evaluate-setups-30d.ts",
    "replay-missing-days": "tsx scripts/replay-missing-days.ts",
    "replay-march-9-14": "tsx scripts/replay-march-9-14.ts",
    "backtest-momentum": "tsx scripts/backtest-momentum.ts",
    "backtest-watchlist": "tsx scripts/backtest-watchlist.ts",
    "scan-now": "tsx scripts/scan-now.ts",
    "monitor-update": "tsx scripts/monitor-update.ts",
    "rebuild-history": "tsx scripts/rebuild-history.ts",
    "evaluate-retro": "tsx scripts/evaluate-retro.ts",
    "validate-scan": "tsx scripts/validate-scan.ts",
    "regenerate-results": "tsx scripts/regenerate-results.ts",
    "evaluate-retro-advanced": "tsx scripts/evaluate-retro-advanced.ts",
    "analyze-criteria-importance": "tsx scripts/analyze-criteria-importance.ts",
    "preview-report": "tsx scripts/preview-report.ts",
    "tv-sync": "tsx scripts/sync-tv-watchlist.ts",
    "export-tv-cookies": "tsx scripts/export-tv-cookies.ts",
    "recall-3month": "tsx scripts/recall-3month.ts"
  },
  "keywords": [
    "stocks",
    "volume",
    "trading",
    "rvol",
    "telegram",
    "market-analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.3.4",
    "p-limit": "^7.3.0",
    "rss-parser": "^3.13.0",
    "trading-signals": "^7.4.3",
    "yahoo-finance2": "3.13.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
